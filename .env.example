# Copy to .env and fill in real values. Never commit .env.

# --- Postgres ---
# Strong random password for the in-compose Postgres instance.
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=

# --- PhotoShare encryption ---
# Used for gallery secret-key encryption and MFA-token storage. NOT used
# for password storage anymore (BCrypt since 2.0.0). Still required.
# Generate: openssl rand -base64 48
ENCRYPTION_KEY=
# Generate: openssl rand -base64 48
ENCRYPTION_SALT=

# --- Initial admin account (created on first run) ---
ADMIN_EMAIL=admin@example.com
# Strong random password; you'll change this on first login. App refuses
# to start if this is empty or the literal "admin".
# Generate: openssl rand -base64 24
ADMIN_PASSWORD=

# --- Public URL ---
# Used to build absolute URLs in emails (verification, password reset)
# and for the CSP / cookie scoping. Behind a Cloudflare Tunnel this is
# the public hostname users actually visit.
BASE_URL=http://localhost:5000

# --- Optional: Cloudflare Tunnel sidecar ---
# Token from `cloudflared tunnel token <TUNNEL_NAME>` or the Zero Trust
# dashboard. Leave blank to disable the sidecar.
# CLOUDFLARED_TOKEN=
