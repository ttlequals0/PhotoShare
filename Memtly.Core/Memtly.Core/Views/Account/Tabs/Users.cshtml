@model UsersModel
@using Memtly.Core.Views.Account.Tabs
@using Memtly.Core.Views.Shared

@{
    var userPermissions = User?.Identity?.GetUserPermissions() ?? new Permissions();
    
    var currentPage = 1;
    try
    {
        currentPage = int.Parse((Context.Request.Query.ContainsKey("page") && !string.IsNullOrWhiteSpace(Context.Request.Query["page"])) ? Context.Request.Query["page"].ToString().ToLower() : "1");
    }
    catch { }

    var searchTerm = string.Empty;
    try
    {
        searchTerm = (Context.Request.Query.ContainsKey("term") ? Context.Request.Query["term"].ToString() : string.Empty);
    }
    catch { }
}

<section class="pnl-account pnl-account-users pb-0 pb-lg-0">
    <div class="container px-3 px-lg-1 my-3 my-lg-4">
        <div class="row">
            <div class="col-12">
                <h1 class="display-6">@_localizer["Users"].Value
                    @if (userPermissions.Users.HasFlag(UserPermissions.Create))
                    {
                        <span class="header-actions">
                            <span class="btnAddUser action link-primary-2 pointer" alt="@_localizer["Add_User"].Value" title="@_localizer["Add_User"].Value">
                                <i class="fas fa-user-plus"></i>
                                <span>@_localizer["Add"].Value</span>
                            </span>
                        </span>
                    }
                </h1>
            </div>
        </div>
        <div class="row mt-3 mb-4">
            <div class="col-12 mb-3 mb-lg-0">
                <label>@_localizer["SearchTerm_Label"].Value</label>
                <input id="users-search-term" class="form-control" type="text" placeholder="" value="@searchTerm" />
                <div class="form-text">@_localizer["SearchTerm_Help"].Value</div>
            </div>
        </div>
        <div class="row pb-5">
            <div id="users-list" class="col-12">
                <partial name="~/Views/Account/Partials/UsersList.cshtml" model="Model" />
            </div>
        </div>
    </div>
</section>