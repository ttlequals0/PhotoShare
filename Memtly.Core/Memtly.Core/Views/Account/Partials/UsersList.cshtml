@model UsersModel
@using Memtly.Core.Views.Account
@using Memtly.Core.Models.Database
@using Memtly.Core.Views.Account.Tabs
@using Memtly.Core.Views.Shared

@{
    var userPermissions = (User?.Identity?.GetUserPermissions() ?? new Permissions());
    var tooltipDisabled = $"({_localizer["Disabled"].Value})";
    var tooltipUpgradeToUnlock = $"({_localizer["Upgrade_To_Unlock"].Value})";

    var currentPage = 1;
    try
    {
        currentPage = int.Parse((Context.Request.Query.ContainsKey("page") && !string.IsNullOrWhiteSpace(Context.Request.Query["page"])) ? Context.Request.Query["page"].ToString().ToLower() : "1");
    }
    catch { }
}

@if (userPermissions.Users.HasFlag(UserPermissions.View) && Model?.Users != null && Model.Users.Any())
{
    <table class="table table-rounded-border">
        <tr>
            <th class="col-5 col-md-4">@_localizer["Name"].Value</th>
            <th class="col-7 col-md-8">@_localizer["Actions"].Value</th>
        </tr>
        @foreach (var user in Model.Users.OrderBy(x => x.Username.ToLower()))
        {
            if (user != null)
            {
                <tr data-user-id="@user.Id" data-user-username="@user.Username" data-user-firstname="@user.Firstname" data-user-lastname="@user.Lastname" data-user-email="@user.Email" data-user-level="@((int)user.Level)" data-modify-level="@userPermissions.Users.HasFlag(UserPermissions.Change_Permissions_Level).ToString().ToLower()">
                    <td class="text-capitalize">@user.Username</td>
                    <td>
                        <!-- ( Edit User ) -->
                        @if (userPermissions.Users.HasFlag(UserPermissions.Update))
                        {
                            var tooltip = _localizer["User_Edit"].Value;
                            
                            <button class="btnEditUser btn btn-primary-3" alt="@tooltip" title="@tooltip">
                                <i class="fas fa-pen-to-square"></i>
                            </button>
                        }

                        <!-- ( Change User Password ) -->
                        @if (userPermissions.Users.HasFlag(UserPermissions.Change_Password))
                        {
                            var tooltip = _localizer["Change_Password"].Value;
                            
                            <button class="btnChangePassword btn btn-primary-3" alt="@tooltip" title="@tooltip">
                                <i class="fas fa-unlock-keyhole"></i>
                            </button>
                        }

                        <!-- ( Reset 2FA ) -->
                        @if (userPermissions.Users.HasFlag(UserPermissions.Reset_MFA))
                        {
                            if (!string.IsNullOrWhiteSpace(user.MultiFactorToken))
                            {
                                var tooltip = _localizer["Wipe_2FA"].Value;
                                <button class="btnWipe2FA btn btn-danger" alt="@tooltip" title="@tooltip">
                                    <i class="fas fa-key"></i>
                                </button>
                            }
                            else
                            {
                                var tooltip = _localizer["2FA_Not_Set"].Value;
                                <button class="btn btn-disabled" disabled=disabled alt="@tooltip" title="@tooltip @tooltipDisabled">
                                    <i class="fas fa-lock-open"></i>
                                </button>
                            }
                        }

                        <!-- ( Freeze / Un-Freeze User ) -->
                        @if (userPermissions.Users.HasFlag(UserPermissions.Freeze))
                        {
                            if (user.State == AccountState.PendingActivation)
                            {
                                var tooltip = _localizer["Activate"].Value;
                                <button class="btnActivateUser btn btn-primary-3" alt="@tooltip" title="@tooltip">
                                    <i class="fas fa-hourglass-half"></i>
                                </button>
                            }
                            else if (user.State == AccountState.Frozen)
                            {
                                var tooltip = _localizer["Unfreeze"].Value;
                                <button class="btnUnfreezeUser btn btn-primary-3" alt="@tooltip" title="@tooltip">
                                    <i class="fas fa-fire"></i>
                                </button>
                            }
                            else
                            {
                                var tooltip = _localizer["Freeze"].Value;
                                <button class="btnFreezeUser btn btn-danger" alt="@tooltip" title="@tooltip">
                                    <i class="fas fa-snowflake"></i>
                                </button>
                            }
                        }

                        <!-- ( Delete User ) -->
                        @if (userPermissions.Users.HasFlag(UserPermissions.Delete))
                        {
                            var tooltip = _localizer["Delete"].Value;
                            
                            <button class="btnDeleteUser btn btn-danger" alt="@tooltip" title="@tooltip">
                                <i class="fas fa-trash-can"></i>
                            </button>
                        }
                    </td>
                </tr>
            }
        }
    </table>

    <div class="row mt-5">
        <div class="col-12">
            <partial name="~/Views/Shared/_Pagination.cshtml" model="new PaginationModel() { CurrentPage = currentPage, TotalItems = Model?.TotalItems ?? 0, ItemsPerPage = Model?.TotalItemsPerPage ?? 50 }" />
        </div>
    </div>
}
else
{
    <div class="col-12 text-center border border-primary-1 rounded py-3 py-lg-4">
        <h3 class="display-6">@_localizer["No_Data"].Value</h3>
    </div>
}