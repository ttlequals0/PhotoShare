@model Memtly.Core.Views.Account.Settings.Gallery.GalleryOverridesModel
@using Memtly.Core.Constants

@if (Model?.Settings != null && Model.Settings.Any())
{
    <h5 class="mb-3">@_localizer["Layout"].Value</h5>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_FullWidth_Label"].Value</label>
            <select class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.FullWidth">
                @foreach (var option in ViewOptions.GalleryWidth)
                {
                    if (Model.Settings.GetValue(MemtlyConfiguration.Gallery.FullWidth.ToUpper(), "false").Equals(option.Value, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option.Value" selected="selected">@option.Key</option>
                    }
                    else
                    {
                        <option value="@option.Value">@option.Key</option>
                    }
                }
            </select>
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_FullWidth_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container setting-advanced">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_Columns_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.Columns" placeholder="1, 2, 3, 4, 6 or 12" value="@Model.Settings.GetValue(MemtlyConfiguration.Gallery.Columns.ToUpper(), string.Empty)" type="number" min="1" max="12" step="1" />
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_Columns_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container setting-advanced">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_ItemsPerPage_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.ItemsPerPage" placeholder="50" value="@Model.Settings.GetValue(MemtlyConfiguration.Gallery.ItemsPerPage.ToUpper(), string.Empty)" type="number" min="1" max="5000" step="10" />
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_ItemsPerPage_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_ShowTitle_Label"].Value</label>
            <select class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.ShowTitle">
                @foreach (var option in ViewOptions.YesNo)
                {
                    if (Model.Settings.GetValue(MemtlyConfiguration.Gallery.ShowTitle.ToUpper(), "true").Equals(option.Value, StringComparison.OrdinalIgnoreCase))
                    {
                        <option value="@option.Value" selected="selected">@option.Key</option>
                    }
                    else
                    {
                        <option value="@option.Value">@option.Key</option>
                    }
                }
            </select>
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_ShowTitle_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_BannerImage_Label"].Value</label>
            <select class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.BannerImage" placeholder="my-banner.jpg">
                <option value="">None</option>
                @{
                    var currentValue = Model.Settings.GetValue(MemtlyConfiguration.Gallery.BannerImage.ToUpper(), string.Empty);
                    if (Model?.CustomResources != null && Model.CustomResources.Any())
                    {
                        foreach (var option in Model.CustomResources)
                        {
                            var path = $"/custom_resources/{option.FileName}";
                            if (currentValue.Equals(path, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@path" selected="selected">@option.Title</option>
                            }
                            else
                            {
                                <option value="@path">@option.Title</option>
                            }
                        }
                    }
                    else if (!string.IsNullOrWhiteSpace(currentValue))
                    {
                        <option value="@currentValue" selected="selected">@currentValue?.Split(new[] { '/' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)?.LastOrDefault()</option>
                    }
                }
            </select>
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_BannerImage_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_Gallery_Quote_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Gallery.Quote" placeholder="Thank you for attending" value="@Model.Settings.GetValue(MemtlyConfiguration.Gallery.Quote.ToUpper(), string.Empty)" type="text" />
            <div class="setting-hint form-text">@_localizer["Settings_Gallery_Quote_Help"].Value</div>
        </div>
    </div>
}