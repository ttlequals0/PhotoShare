@model IDictionary<string, string>?
@using Memtly.Core.Constants

@if (Model != null && Model.Any())
{
    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_BackgroundServices_DirectoryScanner_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.BackgroundServices.DirectoryScanner.Schedule" placeholder="*/30 * * * *" value="@Model.GetValue(MemtlyConfiguration.BackgroundServices.DirectoryScanner.Schedule.ToUpper(), "*/30 * * * *")" type="text" />
            <div class="setting-hint form-text">@_localizer["Settings_BackgroundServices_DirectoryScanner_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_BackgroundServices_EmailReport_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.Reports.Email.Schedule" placeholder="0 0 * * *" value="@Model.GetValue(MemtlyConfiguration.Reports.Email.Schedule.ToUpper(), "0 0 * * *")" type="text" />
            <div class="setting-hint form-text">@_localizer["Settings_BackgroundServices_EmailReport_Help"].Value</div>
        </div>
    </div>

    <div class="row mb-4 mb-lg-4 setting-container">
        <div class="col-12">
            <label class="setting-label">@_localizer["Settings_BackgroundServices_Cleanup_Label"].Value</label>
            <input class="setting-field form-control" data-setting-name="@MemtlyConfiguration.BackgroundServices.Cleanup.Schedule" placeholder="0 4 * * *" value="@Model.GetValue(MemtlyConfiguration.BackgroundServices.Cleanup.Schedule.ToUpper(), "0 4 * * *")" type="text" />
            <div class="setting-hint form-text">@_localizer["Settings_BackgroundServices_Cleanup_Help"].Value</div>
        </div>
    </div>
}