@model Memtly.Core.Models.PhotoGallery

@using Memtly.Core.Constants
@using Memtly.Core.Views.Gallery.Modes

@{
    var slideshowSlideInterval = TimeSpan.FromSeconds(await _settings.GetOrDefault(MemtlyConfiguration.Slideshow.Interval, 10)).TotalMilliseconds;
    var slideshowFadeInterval = await _settings.GetOrDefault(MemtlyConfiguration.Slideshow.Fade, 500);
    var slideLimit = await _settings.GetOrDefault(MemtlyConfiguration.Slideshow.Limit, int.MaxValue);
    var identityEnabled = await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.Enabled, true);

    if (Model?.Images != null)
    {
        <div id="gallery-slideshow" class="slideshow col-12">
            @foreach (var image in Model.Images.Take(slideLimit))
            {
                <div class="slideshow-slide">
                    <img src="@image.ImagePath" class="slideshow-slide-img shadow-1-strong" loading="lazy" />
                    @if (identityEnabled)
                    {
                        <h6 class="credits text-contrast">@_localizer["Uploaded_By"].Value: @(!string.IsNullOrWhiteSpace(image?.UploadedBy) ? image.UploadedBy : "Anonymous")</h6>
                    }
                </div>
            }

            @if (await _settings.GetOrDefault(MemtlyConfiguration.Slideshow.IncludeShareSlide, true))
            {
                <div class="slideshow-slide">
                    <span class="slideshow-slide-img share-slide" data-value="@Html.Raw(ViewBag.QRCodeLink)"></span>
                    <h6 class="credits text-contrast">@_localizer["Scan_To_Share"].Value</h6>
                </div>
            }
        </div>
    }

    <input type="hidden" id="slideshowSlideInterval" value="@slideshowSlideInterval" />
    <input type="hidden" id="slideshowFadeInterval" value="@slideshowFadeInterval" />
}