@model Memtly.Core.Models.PhotoGallery

@using Memtly.Core.Constants
@using Memtly.Core.Views.Gallery.Modes

@{
    var userPermissions = User?.Identity?.GetUserPermissions() ?? new Permissions();
    var columnCount = await _settings.GetOrDefault(MemtlyConfiguration.Gallery.Columns, 4, Model?.Gallery?.Id);
    var identityEnabled = await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.Enabled, true);

    try
    {
        switch (Model?.ViewMode ?? ViewMode.Default)
        {
            case ViewMode.Single:
                {
                    columnCount = 1;
                    break;
                }
            default:
                {
                    if (ViewBag.IsMobile ?? false)
                    {
                        columnCount = 2;
                    }
                    else
                    {
                        while (12 % columnCount != 0)
                        {
                            columnCount--;
                        }
                    }
                    break;    
                }
        }
    }
    catch { }

    IEnumerable<IGrouping<string?, PhotoGalleryImage>>? imageGroups = null;
    if (Model?.Images != null && Model.Images.Any())
    {
        switch (Model?.GroupBy ?? GalleryGroup.Date)
        {
            case GalleryGroup.Date:
                imageGroups = Model?.Images?.GroupBy(x => (x.UploadDate != null ? x.UploadDate.Value.ToString("dddd, d MMMM yyyy") : "Unknown"));
                switch (Model?.OrderBy ?? GalleryOrder.Descending)
                {
                    case GalleryOrder.Ascending:
                        imageGroups = imageGroups?.OrderBy(x => x.FirstOrDefault()?.UploadDate ?? new DateTime());
                        break;
                    case GalleryOrder.Random:
                        imageGroups = imageGroups?.OrderBy(x => Guid.NewGuid());
                        break;
                    default:
                        imageGroups = imageGroups?.OrderByDescending(x => x.FirstOrDefault()?.UploadDate ?? new DateTime());
                        break;
                }
                break;
            case GalleryGroup.MediaType:
                imageGroups = Model?.Images?.GroupBy(x => x.MediaType.ToString());
                switch (Model?.OrderBy ?? GalleryOrder.Descending)
                {
                    case GalleryOrder.Ascending:
                        imageGroups = imageGroups?.OrderBy(x => x.Key);
                        break;
                    case GalleryOrder.Random:
                        imageGroups = imageGroups?.OrderBy(x => Guid.NewGuid());
                        break;
                    default:
                        imageGroups = imageGroups?.OrderByDescending(x => x.Key);
                        break;
                }
                break;
            case GalleryGroup.Uploader:
                imageGroups = Model?.Images?.GroupBy(x => !string.IsNullOrWhiteSpace(x.UploadedBy) ? x.UploadedBy : "Anonymous");
                switch (Model?.OrderBy ?? GalleryOrder.Descending)
                {
                    case GalleryOrder.Ascending:
                        imageGroups = imageGroups?.OrderBy(x => x.Key);
                        break;
                    case GalleryOrder.Random:
                        imageGroups = imageGroups?.OrderBy(x => Guid.NewGuid());
                        break;
                    default:
                        imageGroups = imageGroups?.OrderByDescending(x => x.Key);
                        break;
                }
                break;
            default:
                imageGroups = Model?.Images?.GroupBy(x => x.GalleryName ?? "Default");
                switch (Model?.OrderBy ?? GalleryOrder.Descending)
                {
                    case GalleryOrder.Ascending:
                        imageGroups = imageGroups?.OrderBy(x => x.Key);
                        break;
                    case GalleryOrder.Random:
                        imageGroups = imageGroups?.OrderBy(x => Guid.NewGuid());
                        break;
                    default:
                        imageGroups = imageGroups?.OrderByDescending(x => x.Key);
                        break;
                }
                break;
        }
    }
}

@if (imageGroups != null)
{
    foreach (var imageGroup in imageGroups)
    {
        if (Model?.GroupBy != GalleryGroup.None)
        {
            <h1 class="display-7">@imageGroup.Key
                @if (Model?.Gallery?.Id > 0 && (await _settings.GetOrDefault(MemtlyConfiguration.Gallery.Download, true, Model?.Gallery?.Id) || (User?.Identity != null && User.Identity.IsAuthenticated)))
                {
                    <span class="header-actions">
                        <span class="btnDownloadGroup action link-primary-2 pointer" data-gallery-id="@Model?.Gallery?.Id" data-gallery-name="@Model?.Gallery?.Name" data-gallery-key="@Model?.SecretKey" data-group-name="@((int?)Model?.GroupBy)|@imageGroup.Key" alt="@_localizer["Download"].Value">
                            <i class="fas fa-download"></i>
                            <span>@_localizer["Download"].Value</span>
                        </span>
                    </span>
                }
            </h1>
        }

        var imageGroupImages = Model?.OrderBy == GalleryOrder.Random ? imageGroup.OrderBy(x => Guid.NewGuid()).ToList() : imageGroup.ToList();
        for (var columnIndex = 0; columnIndex < columnCount; columnIndex++)
        {
            <div class="@($"col-{12 / columnCount} mb-4 mb-lg-0 mx-0 px-1")">
                @if (imageGroupImages != null)
                {
                    var index = columnIndex;
                    while (index < imageGroupImages.Count())
                    {
                        var image = imageGroupImages.ElementAt(index);

                        <div class="image-tile mb-2">
                            <a href="@image.ImagePath" class="media-viewer-item" data-media-viewer-id="@image.Id" data-media-viewer-index="@index" data-media-viewer-collection="@image.GalleryName" data-media-viewer-type="gallery_item">
                                <img src="@image?.ThumbnailPath" class="w-100 shadow-1-strong" loading="lazy" />
                                @if (image?.MediaType == MediaType.Video)
                                {
                                    <img src="/_content/Memtly.Core/images/play-button.svg" class="media-viewer-play" loading="lazy" />
                                }
                                @if (User?.Identity != null && User.Identity.IsAuthenticated)
                                {
                                    if (userPermissions.Gallery.HasFlag(GalleryPermissions.Download))
                                    {
                                        <i class="fa fa-square btn-multi-select" data-id="@image?.Name"></i>
                                    }
                                    if (userPermissions.Review.HasFlag(ReviewPermissions.Delete))
                                    {
                                        <i class="fa fa-trash btnDeletePhoto btn-delete-item d-lg-none" data-photo-id="@image?.Id" data-photo-name="@image?.Name"></i>
                                    }
                                }
                            </a>
                        </div>

                        index += columnCount;
                    }
                }
            </div>
        }
    }

    var idleTimeout = await _settings.GetOrDefault(MemtlyConfiguration.Gallery.IdleRefreshMins, 0, Model?.Gallery?.Id);
    if (idleTimeout > 0)
    {
        <input id="galleryIdleRefreshInterval" type="hidden" value="@(TimeSpan.FromMinutes(idleTimeout).TotalMilliseconds)" />
    }
}