@using Memtly.Core.Constants
@using Memtly.Core.Helpers
@inject Memtly.Core.Helpers.IConfigHelper _config
@inject Memtly.Core.Helpers.ILanguageHelper _language
@inject Memtly.Core.Helpers.Database.IDatabaseHelper _database
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment

@{
    var galleryIdentifier = (!string.IsNullOrWhiteSpace(ViewBag?.GalleryIdentifier) && !ViewBag.GalleryIdentifier.Equals(SystemGalleries.AllGallery, StringComparison.OrdinalIgnoreCase)) ? ViewBag.GalleryIdentifier.ToLower() : "default";
    var galleryId = (_database?.GetGalleryId(galleryIdentifier)?.Result) ?? 1;

    var title = await _settings.GetOrDefault(MemtlyConfiguration.Basic.Title, "Memtly", galleryId);
    var isDemoMode = await _settings.GetOrDefault(MemtlyConfiguration.IsDemoMode, false);

    var logo = "/images/logo.png";
    try
    {
        logo = await _settings.GetOrDefault(MemtlyConfiguration.Basic.Logo, "/images/logo.png", galleryId);
    }
    catch
    {
        logo = "/images/logo.png";
    }

    var viewMode = ViewBag?.ViewMode != null ? ViewBag.ViewMode : ViewMode.Default;

    string theme = await _settings.GetOrDefault(MemtlyConfiguration.Themes.Default, Themes.AutoDetect.ToString().ToLower());
    try
    {
        var selectedTheme = Context?.Request?.Cookies["Theme"]?.Trim();
        if (!string.IsNullOrWhiteSpace(selectedTheme))
        { 
            foreach (Themes t in Enum.GetValues(typeof(Themes)))
            {
                if (MemtlyCore.Version == MemtlyVersion.Community && (t == Themes.Green || t == Themes.DarkGreen))
                {
                    continue;
                }

                if (selectedTheme.Equals(t.ToString(), StringComparison.OrdinalIgnoreCase))
                {
                    theme = t.ToString().ToLower();
                    break;
                }
            }
        }
    }
    catch
    {
        theme = Themes.AutoDetect.ToString().ToLower();
    }

    string? culture;
    try
    {
        culture = Context?.Session?.GetString(SessionKey.Language.Selected)?.Trim();
        if (string.IsNullOrEmpty(culture))
        {
            culture = await _language.GetOrFallbackCulture(string.Empty, await _settings.GetOrDefault(MemtlyConfiguration.Languages.Default, "en-GB"));
        }
    }
    catch
    {
        culture = "en-GB";
    }

    bool identityCheck = (await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.Enabled, true) && await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.ShowOnPageLoad, true) && string.IsNullOrWhiteSpace(Context?.Session?.GetString(SessionKey.Viewer.Identity)));
}

<!DOCTYPE html>
<html lang="en">
    <head>
        <title>@title</title>
        <link rel="icon" type="image/png" sizes="32x32" href="~/icons/icon-32.png" />
        <link rel="icon" type="image/png" sizes="16x16" href="~/icons/icon-16.png" />

        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, user-scalable=no" />
        <meta name="description" content="" />
        <meta name="author" content="" />

        <link rel="manifest" href="~/manifest.webmanifest" />
        <meta name="theme-color" content="#1b1938" media="(prefers-color-scheme: dark)" />
        <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <meta name="apple-mobile-web-app-title" content="@title" />
        <link rel="apple-touch-icon" sizes="180x180" href="~/icons/icon-180.png" />

        <link rel="stylesheet" href="~/_content/Memtly.Core/dist/main.css" asp-append-version="true" />
        @if (theme.Equals(Themes.AutoDetect.ToString().ToLower(), StringComparison.OrdinalIgnoreCase))
        {
            if (MemtlyCore.Version == MemtlyVersion.Community)
            {
                <link rel="stylesheet" href="~/_content/Memtly.Core/dist/themes/blue.css" media="(prefers-color-scheme: light), (prefers-color-scheme: no-preference)" asp-append-version="true" />
                <link rel="stylesheet" href="~/_content/Memtly.Core/dist/themes/darkblue.css" media="(prefers-color-scheme: dark)" asp-append-version="true" />
            }
            else
            {
                <link rel="stylesheet" href="~/_content/Memtly.Core/dist/themes/green.css" media="(prefers-color-scheme: light), (prefers-color-scheme: no-preference)" asp-append-version="true" />
                <link rel="stylesheet" href="~/_content/Memtly.Core/dist/themes/darkgreen.css" media="(prefers-color-scheme: dark)" asp-append-version="true" />
            }
        }
        else
        {
            <link rel="stylesheet" href="~/_content/Memtly.Core/dist/themes/@(theme).css" asp-append-version="true" />
        }
    </head>
    <body data-theme="@theme" data-identity-check="@identityCheck.ToString().ToLower()">
        <!-- Navigation -->
        <nav class="navbar navbar-expand-lg">
            <div class="container px-3 px-lg-5 @(viewMode == ViewMode.Presentation || viewMode == ViewMode.Slideshow ? "justify-content-center" : string.Empty)">
                <a class="navbar-brand" href="@(await _settings.GetOrDefault(MemtlyConfiguration.Basic.HomeLink, true) ? "/" : "#")">
                    <picture>
                        <source srcset="/images/photoshare-logo-dark.svg" media="(prefers-color-scheme: dark)" />
                        <img class="navbar-logo" src="@logo" alt="PhotoShare" />
                    </picture>
                    <span class="navbar-title">@title</span>
                </a>
                
                @if (viewMode != ViewMode.Presentation && viewMode != ViewMode.Slideshow)
                {
                    <div class="navbar-options presentation-hidden">
                        <div class="mx-0 mx-lg-4 my-1 float-start">
                            <!-- ( Change Language ) -->
                            @if (await _settings.GetOrDefault(MemtlyConfiguration.Languages.Enabled, true))
                            {
                                var tooltip = _localizer["Language_Change"].Value;
                                <span alt="@tooltip" title="@tooltip">
                                    <i class="change-language fas fa-earth-europe fa-1x text-secondary pointer mx-2"></i>
                                </span>
                            }

                            <!-- ( Change Theme ) -->
                            @if (await _settings.GetOrDefault(MemtlyConfiguration.Themes.Enabled, true))
                            {
                                var tooltip = _localizer["Change_Theme"].Value;
                                <span alt="@tooltip" title="@tooltip">
                                    <i class="change-theme fas fa-palette fa-1x text-secondary pointer mx-2"></i>
                                </span>
                            }

                            <!-- ( Change Identity ) -->
                            @if (await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.Enabled, true))
                            {
                                var requireEmail = await _settings.GetOrDefault(MemtlyConfiguration.IdentityCheck.RequireEmail, false);
                                var tooltip = _localizer["Change_Identity"].Value;
                                <span alt="@tooltip" title="@tooltip">
                                    <i class="change-identity fas fa-id-card fa-1x text-secondary pointer mx-2" data-identity-name="@Context?.Session.GetString(SessionKey.Viewer.Identity)" @(requireEmail ? $"data-identity-email={Context?.Session.GetString(SessionKey.Viewer.EmailAddress)}" : string.Empty)></i>
                                </span>
                            }
                            
                            <!-- ( Set MFA ) -->
                            @if (User?.Identity != null && User.Identity.IsAuthenticated && !string.IsNullOrWhiteSpace(Context?.Request.Path.Value) && Context.Request.Path.Value.Contains("/Account", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/Login", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/Register", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/ForgotPassword", StringComparison.OrdinalIgnoreCase))
                            {
                                var tooltip = _localizer["2FA_Setup"].Value;
                                <span alt="@tooltip" title="@tooltip">
                                    <i class="change-2fa fas fa-key fa-1x text-secondary pointer mx-2" data-mfa-set="@(bool.Parse(Context?.Session.GetString(SessionKey.MultiFactor.TokenSet)?.ToLower() ?? "false").ToString().ToLower())"></i>
                                </span>
                            }
                        </div>
                        <div class="profile-icon my-1 m-lg-0 float-end">
                            @if (await _settings.GetOrDefault(MemtlyConfiguration.Account.ShowProfileIcon, true))
                            {
                                if (!string.IsNullOrWhiteSpace(Context?.Request.Path.Value) && Context.Request.Path.Value.Contains("/Account", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/Login", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/Register", StringComparison.OrdinalIgnoreCase) && !Context.Request.Path.Value.Contains("/ForgotPassword", StringComparison.OrdinalIgnoreCase))
                                {
                                    var tooltip = _localizer["Logout"].Value;
                                    <a href="@Url.Action("Logout", "Account")" alt="@tooltip" title="@tooltip">
                                        <i class="fas fa-door-open fa-2x"></i>
                                    </a>
                                }
                                else
                                {
                                    var tooltip = _localizer["Login"].Value;
                                    <a href="@Url.Action("Login", "Account")" alt="@tooltip" title="@tooltip">
                                        <i class="fas fa-circle-user fa-2x text-secondary"></i>
                                    </a>
                                }
                            }
                        </div>
                    </div>
                }
            </div>
        </nav>

        <!-- Body -->
        <div id="main-wrapper">
            @if (isDemoMode)
            {
                <div class="alert alert-warning header-alert text-center" role="alert">
                    <i class="fa fa-warning mx-3"></i><b>@(_localizer["Warning"].Value.ToUpper()):</b> @_localizer["Demo_Message"].Value
                </div>
            }

            @{
                try
                {
                    var errorMessage = ViewBag.ErrorMessage;
                    if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-exclamation-triangle-fill flex-shrink-0 me-2" viewBox="0 0 16 16" role="img" aria-label="Warning:">
                                <path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                            </svg>
                            <div>
                                @errorMessage
                            </div>
                        </div>
                    }
                }
                catch { }
            }

            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="py-1">
            <div class="container">
                <p class="m-0 text-white">
                    <span class="float-none">
                        <a class="text-link" href="@_config.GetConfigValue(MemtlyStaticConfiguration.Links.GitHub)" title="Copyright PhotoShare" target="_blank"><i class="fa-brands fa-github"></i> v@(_settings.GetReleaseVersion(3)) &copy; PhotoShare @DateTime.UtcNow.Year</a>
                    </span>
                </p>
            </div>
        </footer>

        <!-- GDPR Cookie Consent -->
        <partial name="_CookieConsentPartial" />

        <!-- Anti-forgery token rendered once so JS can read it for the
             RequestVerificationToken header (see main.js $.ajaxSetup). -->
        @Html.AntiForgeryToken()

        <!-- Webpack -->
        <script src="~/_content/Memtly.Core/dist/main.js" asp-append-version="true"></script>

        @await RenderSectionAsync("Scripts", required: false)

        <partial name="~/Views/Shared/_Trackers.cshtml" />
    </body>
</html>