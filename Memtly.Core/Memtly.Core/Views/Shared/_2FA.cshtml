@using TwoFactorAuthNet
@using Memtly.Core.Constants
@using Memtly.Core.Helpers

@{
    var title = await _settings.GetOrDefault(MemtlyConfiguration.Basic.Title, "Memtly");

    var tfa = new TwoFactorAuth(title);

    var secret = Context?.Session?.GetString(SessionKey.MultiFactor.Secret);
    if (string.IsNullOrEmpty(secret))
    {
        try
        {
            secret = tfa.CreateSecret(160);
            Context?.Session.SetString(SessionKey.MultiFactor.Secret, secret);
            <input id="2fa-secret" type="hidden" value="@secret"/>
        }
        catch { }
    }

    var qrCode = Context?.Session?.GetString(SessionKey.MultiFactor.QR);
    if (string.IsNullOrEmpty(qrCode))
    {
        try
        {
            qrCode = tfa.GetQrCodeImageAsDataUri(title, secret);
            Context?.Session.SetString(SessionKey.MultiFactor.QR, qrCode);
            <input id="2fa-qr-code" type="hidden" value="@qrCode" />
        }
        catch { }
    }
}