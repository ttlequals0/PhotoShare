{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Memtly": {
    "Title": "PhotoShare",
    "Logo": "/images/photoshare-logo-light.svg",
    "Base_Url": "",
    "Gallery_Secret_Key": null,
    "Force_Https": true,
    "Single_Gallery_Mode": false,
    "Max_Gallery_Count": 1000000,
    "Home_Link": true,
    "Guest_Gallery_Creation": false,
    "Hide_Key_From_QR_Code": false,
    "Links_Open_New_Tab": false,
    "Thumbnail_Size": 720,
    "Email_Report": true,
    "Demo_Mode": false,
    "Database": {
      "Type": "sqlite",
      "Connection_String": "Data Source=./config/memtly.db",
      "Sync_From_Config": false
    },
    "Security": {
      "MultiFactor": {
        "Reset_To_Default": false
      },
      "Encryption": {
        "Key": "",
        "Salt": "",
        "HashType": "SHA512",
        "Iterations": 600000
      },
      "Headers": {
        "Enabled": true,
        "X_Frame_Options": "SAMEORIGIN",
        "X_Content_Type_Options": "nosniff"
      },
      "Hardening": {
        "Allow_Insecure_Galleries": false
      }
    },
    "Account": {
      "Admin": {
        "Email": "",
        "Password": ""
      },
      "Registration": {
        "Enabled": true,
        "Require_Email_Validation":  true
      },
      "Show_Profile_Icon": true,
      "Lockout_Attempts": 5,
      "Lockout_Mins": 60
    },
    "Gallery_Selector": {
      "Dropdown": false,
      "Hide_Default_Option": false,
      "Show_Gallery_Identifiers": true,
      "Show_Gallery_Names": true,
      "Show_Usernames": true
    },
    "Gallery": {
      "Show_Title": true,
      "Banner_Image": "",
      "Quote": "",
      "Columns": 4,
      "Items_Per_Page": 50,
      "Full_Width": false,
      "Retain_Rejected_Items": false,
      "Likes": true,
      "Upload": true,
      "Download": true,
      "Require_Review": true,
      "Review_Counter": true,
      "Prevent_Duplicates": true,
      "QR_Code": {
        "Enabled": true,
        "Default_View": "",
        "Default_Sort": ""
      },
      "Idle_Refresh_Mins": 5,
      "Max_Size_Mb": 1024,
      "Max_File_Size_Mb": 50,
      "Allowed_File_Types": ".jpg,.jpeg,.png,.mp4,.mov",
      "Default_View": 0,
      "Default_Group": 0,
      "Default_Order": 1,
      "Default_Filter": 0,
      "Upload_Period": "1970-01-01 00:00",
      "Camera_Uploads": false,
      "Show_Filters": true
    },
    "Slideshow": {
      "Interval": 10,
      "Fade": 500,
      "Limit": 50,
      "Include_Share_Slide": true
    },
    "Audit": {
      "Enabled": true,
      "Retention": 30
    },
    "Identity_Check": {
      "Enabled": true,
      "Require_Name": false,
      "Require_Email": false,
      "Show_On_Page_Load": true,
      "Require_Identity_For_Upload": false
    },
    "Policies": {
      "Enabled": false,
      "CookiePolicy": ""
    },
    "Notifications": {
      "Alerts": {
        "Failed_Login": true,
        "Account_Lockout": true,
        "Destructive_Action": true,
        "Pending_Review": true
      },
      "Smtp": {
        "Enabled": false,
        "Recipient": "",
        "Host": "",
        "Port": 587,
        "Username": "",
        "Password": "",
        "From": "",
        "DisplayName": "Memtly",
        "Use_SSL": true
      },
      "Ntfy": {
        "Enabled": false,
        "Endpoint": "",
        "Token": "",
        "Topic": "Memtly",
        "Priority": 4,
        "Icon": "https://raw.githubusercontent.com/Memtly/Memtly.Assets/master/Logos/Community/Memtly.png"
      },
      "Gotify": {
        "Enabled": false,
        "Endpoint": "",
        "Token": "",
        "Priority": 4,
        "Icon": "https://raw.githubusercontent.com/Memtly/Memtly.Assets/master/Logos/Community/Memtly.png"
      }
    },
    "Trackers": {
      "Umami": {
        "Endpoint": "",
        "ScriptName": "script.js",
        "WebsiteId": "",
        "PerformanceTracking": {
          "Enabled": false
        },
        "Replay": {
          "Enabled": false,
          "SampleRate": 0.15,
          "MaskLevel": 0,
          "MaxDuration": 5,
          "BlockSelector": ""
        }
      }
    },
    "Reports": {
      "Email": {
        "Enabled": true,
        "Schedule": "0 0 * * *"
      }
    },
    "Themes": {
      "Enabled": true,
      "Default": "AutoDetect"
    },
    "Languages": {
      "Enabled": true,
      "Default": "en-GB"
    },
    "Sponsors": {
      "Url": "https://sponsors.memtly.com",
      "Endpoint": "/api/all",
      "Github": {
        "ProfileUrl": "https://github.com/"
      }
    },
    "BackgroundServices": {
      "Directory_Scanner": {
        "Enabled": true,
        "Schedule": "*/30 * * * *"
      },
      "Cleanup": {
        "Enabled": true,
        "Schedule": "0 4 * * *"
      }
    }
  },
  "Links": {
    "GitHub": "https://github.com/ttlequals0/PhotoShare",
    "GitHubSponsors": "https://github.com/sponsors/ttlequals0",
    "GitHubStargazers": "https://github.com/ttlequals0/PhotoShare/stargazers",
    "BuyMeACoffee": "https://buymeacoffee.com/memtly"
  },
  "AllowedHosts": "*"
}